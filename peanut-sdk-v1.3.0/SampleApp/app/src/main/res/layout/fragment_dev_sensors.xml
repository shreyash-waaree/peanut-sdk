<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Live Sensor Feed"
                android:textColor="#0E1230"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_sensors_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connecting…"
                android:textColor="#1565C0"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Battery -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Battery"
                        android:textStyle="bold"
                        android:textColor="#1565C0" />
                    <TextView
                        android:id="@+id/tv_battery_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#0E1230" />
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/pb_battery"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="14dp"
                    android:layout_marginTop="6dp"
                    android:max="100"
                    android:progress="0" />
                <TextView
                    android:id="@+id/tv_battery_hb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="No updates yet"
                    android:textSize="11sp"
                    android:textColor="#607D8B" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Position -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Position (live chassis pose)"
                    android:textStyle="bold"
                    android:textColor="#1565C0" />
                <TextView
                    android:id="@+id/tv_position_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="x: —   y: —   θ: —"
                    android:textSize="16sp"
                    android:layout_marginTop="4dp" />
                <TextView
                    android:id="@+id/tv_position_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#0E1230"
                    android:text="Floor —"
                    android:layout_marginTop="2dp" />
                <TextView
                    android:id="@+id/tv_position_hb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#607D8B"
                    android:text="No updates yet" />
                <TextView
                    android:id="@+id/tv_position_path"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textColor="#8E99B5"
                    android:text="SDK: OBSERVE /position/robotPosInfo" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- IMU -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IMU (orientation)"
                    android:textStyle="bold"
                    android:textColor="#1565C0" />
                <TextView
                    android:id="@+id/tv_imu_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:layout_marginTop="4dp"
                    android:text="Yaw —   Pitch —   Roll —" />
                <TextView
                    android:id="@+id/tv_imu_hb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#607D8B"
                    android:text="No updates yet" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:textColor="#0E1230"
                        android:text="ROS bridge (ws://192.168.64.20:9090 /imu_raw)" />
                    <Switch
                        android:id="@+id/sw_imu_ros"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_imu_path"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textColor="#8E99B5"
                    android:text="SDK: OBSERVE /sensor/imuangle  +  OBSERVE /sensor/imu" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- LiDAR — navigation sensor.lidar with decoded point cloud + radar visual -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="LiDAR (navigation)"
                        android:textStyle="bold"
                        android:textColor="#1565C0" />
                    <TextView
                        android:id="@+id/tv_lidar_hb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#607D8B"
                        android:text="No updates yet" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:textColor="#0E1230"
                        android:text="Synthetic demo (radar without live CoAP)" />
                    <Switch
                        android:id="@+id/sw_lidar_demo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:textColor="#0E1230"
                        android:text="ROS bridge (ws://192.168.64.20:9090 /scan)" />
                    <Switch
                        android:id="@+id/sw_lidar_ros"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_lidar_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textColor="#C62828"
                    android:visibility="gone"
                    android:layout_marginTop="4dp"
                    android:text="" />

                <TextView
                    android:id="@+id/tv_lidar_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:text="Waiting for LiDAR…" />

                <TextView
                    android:id="@+id/tv_lidar_closest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#0E1230"
                    android:layout_marginTop="4dp"
                    android:text="Closest — (no returns yet)" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#0E1230"
                        android:text="Radar range (m): " />
                    <EditText
                        android:id="@+id/et_lidar_range"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="numberDecimal"
                        android:hint="e.g. 15"
                        android:textSize="12sp"
                        android:maxLines="1" />
                    <Button
                        android:id="@+id/btn_lidar_range_apply"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Apply"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#0E1230"
                        android:text="Max points: " />
                    <EditText
                        android:id="@+id/et_lidar_max_points"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="number"
                        android:hint="blank = all"
                        android:textSize="12sp"
                        android:maxLines="1" />
                    <Button
                        android:id="@+id/btn_lidar_max_points_apply"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Apply"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.keenon.peanut.supermarket.widget.LidarRadarView
                    android:id="@+id/view_lidar_radar"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="8dp"
                    android:background="#FFFFFF" />

                <TextView
                    android:id="@+id/tv_lidar_sectors"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#607D8B"
                    android:fontFamily="monospace"
                    android:layout_marginTop="6dp"
                    android:text="Sectors (m): —" />
                <TextView
                    android:id="@+id/tv_lidar_path"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textColor="#8E99B5"
                    android:text="SDK: OBSERVE /sensor/lidar (raw bytes)" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Sonar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sonar"
                        android:textStyle="bold"
                        android:textColor="#1565C0" />
                    <TextView
                        android:id="@+id/tv_sonar_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textStyle="bold"
                        android:textSize="16sp" />
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/pb_sonar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="6dp"
                    android:max="100"
                    android:progress="0" />
                <TextView
                    android:id="@+id/tv_sonar_hb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#607D8B"
                    android:layout_marginTop="4dp"
                    android:text="No updates yet" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:textColor="#0E1230"
                        android:text="ROS bridge — sonar / bump / collision&#10;(/fdl/obs_low + /bump + /SDS_collision_points)" />
                    <Switch
                        android:id="@+id/sw_safety_ros"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Safety row: collision + bump -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Collision"
                        android:textStyle="bold"
                        android:textColor="#1565C0" />
                    <TextView
                        android:id="@+id/tv_collision_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:padding="8dp"
                        android:layout_marginTop="6dp"
                        android:background="#E0E0E0" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bump / Touch"
                        android:textStyle="bold"
                        android:textColor="#1565C0" />
                    <TextView
                        android:id="@+id/tv_bump_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:padding="8dp"
                        android:layout_marginTop="6dp"
                        android:background="#E0E0E0" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Motor + Navigation + Charge row -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Motor state"
                        android:textColor="#1565C0"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tv_motor_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="6dp"
                    android:background="#E0E0E0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Navigation state"
                        android:textColor="#1565C0"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tv_nav_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="6dp"
                    android:background="#E0E0E0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Charging"
                        android:textColor="#1565C0"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tv_charge_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Topic heartbeat diagnostics -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Topic rates (updates per second)"
                    android:textStyle="bold"
                    android:textColor="#1565C0" />
                <TextView
                    android:id="@+id/tv_topic_rates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:text="—" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
