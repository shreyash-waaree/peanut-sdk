<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111318"
    android:padding="10dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/count2_title"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/count_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/cam_status_idle"
        android:textColor="#B0FFFFFF"
        android:textSize="12sp" />

    <!-- Preview uses full height; ROI + grid controls sit in the right column (no shrink from buttons). -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/count_preview_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#000000">

            <SurfaceView
                android:id="@+id/count_surface"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

            <com.keenon.peanut.supermarket.widget.TrayRoiOverlayView
                android:id="@+id/count_roi_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/count_placeholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Tap Start then pick a tray camera below"
                android:textColor="#88FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/count_big_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="10dp"
                android:background="#CC000000"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="--"
                android:textColor="#FFF59E0B"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/count_status_line"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="6dp"
                android:background="#99000000"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text=""
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:visibility="gone" />
        </FrameLayout>

        <ScrollView
            android:layout_width="158dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:fillViewport="true"
            android:background="#1A2228">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/count2_sidebar_title"
                    android:textColor="#FFF59E0B"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/count_roi_prompt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:padding="6dp"
                    android:background="#33F59E0B"
                    android:text="@string/count_roi_prompt_top"
                    android:textColor="#FFF59E0B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/count_roi_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <Button
                        android:id="@+id/btn_count_roi_confirm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:enabled="false"
                        android:textSize="11sp"
                        android:text="@string/count_roi_confirm" />

                    <Button
                        android:id="@+id/btn_count_roi_reset"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textSize="11sp"
                        android:text="@string/count_roi_reset" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/count2_grid_label"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/count_grid_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/count_grid_2x2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="@string/count2_grid_2x2"
                        android:textColor="#E0E0E0"
                        android:textSize="11sp" />

                    <RadioButton
                        android:id="@+id/count_grid_3x3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/count2_grid_3x3"
                        android:textColor="#E0E0E0"
                        android:textSize="11sp" />

                    <RadioButton
                        android:id="@+id/count_grid_4x4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/count2_grid_4x4"
                        android:textColor="#E0E0E0"
                        android:textSize="11sp" />

                    <RadioButton
                        android:id="@+id/count_grid_2x3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/count2_grid_2x3"
                        android:textColor="#E0E0E0"
                        android:textSize="11sp" />
                </RadioGroup>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/count_index_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_count_start"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/cam_start" />

        <Button
            android:id="@+id/btn_count_stop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:enabled="false"
            android:text="@string/cam_stop" />
    </LinearLayout>
</LinearLayout>
