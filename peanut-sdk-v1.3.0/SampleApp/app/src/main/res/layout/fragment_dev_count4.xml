<?xml version="1.0" encoding="utf-8"?>
<!-- Count4 — Count3 UI + pickup approach-angle log panel. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_count2_screen"
    android:baselineAligned="false"
    android:orientation="horizontal"
    android:padding="10dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        app:cardBackgroundColor="#40050814"
        app:cardCornerRadius="18dp"
        app:cardElevation="10dp"
        app:strokeColor="#5538BDF8"
        app:strokeWidth="1dp">

        <FrameLayout
            android:id="@+id/count_preview_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_count2_preview_frame"
            android:padding="3dp">

            <SurfaceView
                android:id="@+id/count_surface"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

            <com.keenon.peanut.supermarket.widget.TrayRoiOverlayView
                android:id="@+id/count_roi_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/count_placeholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="16dp"
                android:text="@string/count_placeholder"
                android:textColor="#66FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/count_mode_banner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="12dp"
                android:background="@drawable/bg_count_btn_primary"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="@string/count_mode_banner_stocking"
                android:textColor="#FFFFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/count_big_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:background="#DD020617"
                android:fontFamily="sans-serif-medium"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="--"
                android:textColor="#38BDF8"
                android:textSize="44sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/count_status_line"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_margin="10dp"
                android:background="#CC020617"
                android:ellipsize="end"
                android:maxLines="3"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text=""
                android:textColor="#E2E8F0"
                android:textSize="12sp"
                android:visibility="gone" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_marginStart="10dp"
        app:cardBackgroundColor="#E6141933"
        app:cardCornerRadius="18dp"
        app:cardElevation="8dp"
        app:strokeColor="#332563EB"
        app:strokeWidth="1dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.06"
                    android:text="@string/count4_title"
                    android:textColor="#F8FAFC"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/count4_tagline"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp" />

                <TextView
                    android:id="@+id/count_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/cam_status_idle"
                    android:textColor="#64748B"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/count_roi_prompt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="#332563EB"
                    android:padding="10dp"
                    android:text="@string/count_roi_prompt_top"
                    android:textColor="#93C5FD"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_count_start"
                        style="@style/CountPrimaryButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/cam_start" />

                    <Button
                        android:id="@+id/btn_count_stop"
                        style="@style/CountCompactButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:enabled="false"
                        android:text="@string/cam_stop" />
                </LinearLayout>

                <TextView
                    style="@style/CountPanelLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/count_panel_camera"
                    android:textColor="#CBD5E1" />

                <LinearLayout
                    android:id="@+id/count_index_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="vertical" />

                <TextView
                    style="@style/CountPanelLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/count_panel_slots"
                    android:textColor="#CBD5E1" />

                <LinearLayout
                    android:id="@+id/count_slot_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_count_slots_2"
                            style="@style/CountCompactButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:text="2" />

                        <Button
                            android:id="@+id/btn_count_slots_4"
                            style="@style/CountCompactButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="4" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_count_slots_6"
                            style="@style/CountCompactButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:text="6" />

                        <Button
                            android:id="@+id/btn_count_slots_9"
                            style="@style/CountCompactButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="9" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    style="@style/CountPanelLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/count4_angle_panel"
                    android:textColor="#CBD5E1" />

                <TextView
                    android:id="@+id/count4_angle_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="#3322C55E"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="2dp"
                    android:minHeight="48dp"
                    android:padding="10dp"
                    android:text="@string/count4_angle_log_hint"
                    android:textColor="#BBF7D0"
                    android:textSize="11sp" />

                <TextView
                    style="@style/CountPanelLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/count_panel_mode"
                    android:textColor="#CBD5E1" />

                <Button
                    android:id="@+id/btn_count_mode_stocking"
                    style="@style/CountCompactButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/count_mode_stocking" />

                <Button
                    android:id="@+id/btn_count_mode_customer"
                    style="@style/CountCompactButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/count_mode_customer" />

                <Button
                    android:id="@+id/btn_count_roi_edit"
                    style="@style/CountCompactButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/count_roi_edit_short"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/count_roi_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <Button
                        android:id="@+id/btn_count_roi_confirm"
                        style="@style/CountPrimaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:enabled="false"
                        android:text="@string/count_roi_confirm" />

                    <Button
                        android:id="@+id/btn_count_roi_reset"
                        style="@style/CountCompactButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/count_roi_reset" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
