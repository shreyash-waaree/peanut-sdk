<?xml version="1.0" encoding="utf-8"?>
<!--
  YOLO Detection screen — redesigned layout.
  Camera preview fills ~75% of height. Controls live in a compact bottom card.
  An ROI border overlay is drawn on the camera to show the detection zone.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0F14">

    <!-- ═══════════════════════════════════════════════════
         TOP BAR — title + status + FPS badge
         ═══════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/yolo_top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp"
        android:background="#1A1D26"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/yolo_title"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/yolo_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/yolo_status_idle"
                android:textColor="#88AABBFF"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- FPS badge -->
        <TextView
            android:id="@+id/yolo_fps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:background="@drawable/yolo_badge_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:textColor="#FFFFD700"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════
         CAMERA PREVIEW — 4:3 aspect ratio (matches tray camera 640×480)
         Centred between top bar and bottom panel; black bars fill remaining space.
         ═══════════════════════════════════════════════════ -->

    <!-- Camera preview container: fills all space between top bar and bottom card. -->
    <FrameLayout
        android:id="@+id/yolo_preview_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#000000"
        app:layout_constraintTop_toBottomOf="@id/yolo_top_bar"
        app:layout_constraintBottom_toTopOf="@id/yolo_bottom_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Live camera surface — fills the 4:3 container exactly -->
        <SurfaceView
            android:id="@+id/yolo_surface"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

        <!-- Idle placeholder -->
        <LinearLayout
            android:id="@+id/yolo_placeholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷"
                android:textSize="48sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/yolo_placeholder"
                android:textColor="#66FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ROI border: shows the detection zone visually on the camera frame.
             This is a transparent view with only a coloured border drawn by code,
             or we use a simple View with a border drawable defined below.
             Positioned to match ObjectDetectorHelper.ROI_FRAC = 0.70 -->
        <View
            android:id="@+id/yolo_roi_border"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_gravity="center"
            android:background="@drawable/yolo_roi_border"
            android:visibility="gone" />

        <!-- Detection results panel — overlaid bottom-left of camera -->
        <LinearLayout
            android:id="@+id/yolo_detections_panel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="10dp"
            android:background="@drawable/yolo_detection_bg"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/yolo_det_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/yolo_detections"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#FF4CAF50"
                android:textSize="13sp"
                android:lineSpacingExtra="3dp"
                android:visibility="gone" />
        </LinearLayout>

    </FrameLayout>

    <!-- ═══════════════════════════════════════════════════
         BOTTOM CONTROL CARD — compact, all controls in one row-based card
         ═══════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/yolo_bottom_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A1D26"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row 1: Camera index buttons -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/yolo_index_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical" />
        </HorizontalScrollView>

        <!-- Row 2: Camera source + Model selector side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <!-- Camera source -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CAMERA"
                    android:textColor="#88AABBFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <RadioGroup
                    android:id="@+id/yolo_mode_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/yolo_mode_android"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:checked="true"
                        android:text="@string/yolo_mode_android"
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp"
                        android:button="@null"
                        android:drawableStart="@null"
                        android:paddingStart="0dp"
                        android:background="@null" />

                    <RadioButton
                        android:id="@+id/yolo_mode_native"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:text="@string/yolo_mode_native"
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp"
                        android:button="@null"
                        android:drawableStart="@null"
                        android:paddingStart="0dp"
                        android:background="@null" />
                </RadioGroup>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#33FFFFFF"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <!-- Model selector -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MODEL"
                    android:textColor="#88AABBFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <!-- Tray / COCO toggle (kept for quick switch) -->
                <RadioGroup
                    android:id="@+id/yolo_model_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/yolo_model_tray"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:checked="true"
                        android:text="Tray"
                        android:textColor="#FF90EE90"
                        android:textSize="12sp"
                        android:button="@null"
                        android:paddingEnd="8dp"
                        android:background="@null" />

                    <RadioButton
                        android:id="@+id/yolo_model_coco"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:checked="false"
                        android:text="COCO"
                        android:textColor="#FF90EE90"
                        android:textSize="12sp"
                        android:button="@null"
                        android:background="@null" />
                </RadioGroup>

                <!-- TFLite model spinner (only visible in COCO mode); opaque popup + light text -->
                <Spinner
                    android:id="@+id/yolo_tflite_model_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:visibility="gone"
                    android:background="@drawable/yolo_spinner_field_bg"
                    android:popupBackground="@drawable/yolo_spinner_popup_bg"
                    android:dropDownVerticalOffset="4dp"
                    android:spinnerMode="dropdown"
                    android:elevation="12dp" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#33FFFFFF"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <!-- Start OR Stop in same slot (only one visible at a time) -->
            <FrameLayout
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical">

                <Button
                    android:id="@+id/btn_yolo_start"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:text="@string/yolo_start"
                    android:textSize="12sp"
                    android:backgroundTint="#FF1E8A3E"
                    android:textColor="#FFFFFF"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <Button
                    android:id="@+id/btn_yolo_stop"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:enabled="false"
                    android:text="@string/yolo_stop"
                    android:textSize="12sp"
                    android:backgroundTint="#FF8A1E1E"
                    android:textColor="#FFFFFF"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />
            </FrameLayout>
        </LinearLayout>

        <!-- Row 3: Detection Zone sliders (collapsible) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="6dp">

            <!-- Toggle header -->
            <TextView
                android:id="@+id/yolo_zone_toggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▶  DETECTION ZONE"
                android:textColor="#88AABBFF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <!-- Slider panel (collapsed by default) -->
            <LinearLayout
                android:id="@+id/yolo_zone_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Top crop -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="2dp">
                    <TextView android:layout_width="48dp" android:layout_height="wrap_content" android:text="Top" android:textColor="#AAFFFFFF" android:textSize="10sp" />
                    <SeekBar android:id="@+id/yolo_zone_top" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="49" android:progress="0" />
                    <TextView android:id="@+id/yolo_zone_top_val" android:layout_width="32dp" android:layout_height="wrap_content" android:text="0%" android:textColor="#AAFFFFFF" android:textSize="10sp" android:gravity="end" />
                </LinearLayout>

                <!-- Bottom crop -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="2dp">
                    <TextView android:layout_width="48dp" android:layout_height="wrap_content" android:text="Bottom" android:textColor="#AAFFFFFF" android:textSize="10sp" />
                    <SeekBar android:id="@+id/yolo_zone_bottom" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="49" android:progress="0" />
                    <TextView android:id="@+id/yolo_zone_bottom_val" android:layout_width="32dp" android:layout_height="wrap_content" android:text="0%" android:textColor="#AAFFFFFF" android:textSize="10sp" android:gravity="end" />
                </LinearLayout>

                <!-- Left crop -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="2dp">
                    <TextView android:layout_width="48dp" android:layout_height="wrap_content" android:text="Left" android:textColor="#AAFFFFFF" android:textSize="10sp" />
                    <SeekBar android:id="@+id/yolo_zone_left" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="49" android:progress="0" />
                    <TextView android:id="@+id/yolo_zone_left_val" android:layout_width="32dp" android:layout_height="wrap_content" android:text="0%" android:textColor="#AAFFFFFF" android:textSize="10sp" android:gravity="end" />
                </LinearLayout>

                <!-- Right crop -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="2dp">
                    <TextView android:layout_width="48dp" android:layout_height="wrap_content" android:text="Right" android:textColor="#AAFFFFFF" android:textSize="10sp" />
                    <SeekBar android:id="@+id/yolo_zone_right" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="49" android:progress="0" />
                    <TextView android:id="@+id/yolo_zone_right_val" android:layout_width="32dp" android:layout_height="wrap_content" android:text="0%" android:textColor="#AAFFFFFF" android:textSize="10sp" android:gravity="end" />
                </LinearLayout>

                <!-- Reset button -->
                <Button
                    android:id="@+id/yolo_zone_reset"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:layout_marginTop="4dp"
                    android:text="Reset"
                    android:textSize="10sp"
                    android:backgroundTint="#FF333A50"
                    android:textColor="#AAFFFFFF"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
