<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F7F8FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hw_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimaryDark" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:text="@string/hw_sensor_warning"
            android:textColor="#8A000000"
            android:textSize="12sp" />

        <!-- Motion card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hw_motor_section"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary" />

                <TextView
                    android:id="@+id/hw_motor_state_line"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Status: not prepared"
                    android:textSize="12sp"
                    android:textColor="#AA000000" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_hw_prepare"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/hw_prepare_btn" />

                    <Button
                        android:id="@+id/btn_hw_release"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="@string/hw_release_btn" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/hw_hold_hint"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:textColor="#8A000000" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:gravity="center">

                    <Button
                        android:id="@+id/btn_hw_front"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:text="@string/hw_move_front"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <Button
                            android:id="@+id/btn_hw_left"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:text="@string/hw_move_left"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btn_hw_stop"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:layout_marginStart="6dp"
                            android:text="@string/hw_move_stop"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btn_hw_right"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:layout_marginStart="6dp"
                            android:text="@string/hw_move_right"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_hw_back"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginTop="6dp"
                        android:text="@string/hw_move_back"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Sensor card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hw_sensors_section"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/hw_battery_label"
                        android:textStyle="bold" />
                    <TextView android:id="@+id/tv_sensor_battery"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/hw_value_placeholder" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/hw_position_label"
                        android:textStyle="bold" />
                    <TextView android:id="@+id/tv_sensor_position"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/hw_value_placeholder" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/hw_motor_state_label"
                        android:textStyle="bold" />
                    <TextView android:id="@+id/tv_sensor_motor"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/hw_value_placeholder" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/hw_nav_label"
                        android:textStyle="bold" />
                    <TextView android:id="@+id/tv_sensor_nav"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/hw_value_placeholder" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/hw_sonar_label"
                        android:textStyle="bold" />
                    <TextView android:id="@+id/tv_sensor_sonar"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/hw_value_placeholder" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/hw_collision_label"
                        android:textStyle="bold" />
                    <TextView android:id="@+id/tv_sensor_collision"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/hw_value_placeholder" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/hw_charge_label"
                        android:textStyle="bold" />
                    <TextView android:id="@+id/tv_sensor_charge"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/hw_value_placeholder" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/hw_imu_label"
                        android:textStyle="bold" />
                    <TextView android:id="@+id/tv_sensor_imu"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/hw_value_placeholder" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btn_hw_open_receiver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hw_open_receiver_btn" />
    </LinearLayout>
</ScrollView>
