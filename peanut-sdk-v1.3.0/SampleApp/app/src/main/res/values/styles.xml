<resources>

    <!-- Base application theme — kept on AppCompat to match the original SampleApp so demo
         activities (MotorDemo, ChargerDemo, etc.) inflate exactly as they always did. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!-- Supermarket shell only. Material parent is required for MaterialCardView /
         TextInputLayout / MaterialButton used in the supermarket fragments. Applied on the
         SupermarketActivity in AndroidManifest, NOT inherited by demo activities. -->
    <style name="AppTheme.Supermarket" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="TabLabelText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="textAllCaps">false</item>
    </style>

    <style name="CountCompactButton" parent="Widget.AppCompat.Button">
        <item name="android:minHeight">34dp</item>
        <item name="android:paddingLeft">8dp</item>
        <item name="android:paddingRight">8dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:background">@drawable/bg_count_btn_default</item>
        <item name="android:textColor">#E8EAED</item>
    </style>

    <style name="CountPrimaryButton" parent="CountCompactButton">
        <item name="android:background">@drawable/bg_count_btn_primary</item>
        <item name="android:textColor">#1A1D24</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CountPanelLabel" parent="android:Widget.TextView">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">#8B93A7</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.06</item>
    </style>

</resources>
